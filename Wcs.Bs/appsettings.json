{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=wcs.db"
  },
  "Devices": [
    { "Code": "CV01", "Type": "Conveyor", "PlcIp": "127.0.0.1", "PlcPort": 2001 },
    { "Code": "CR01", "Type": "Crane", "PlcIp": "127.0.0.1", "PlcPort": 2002 }
  ],
  "Plc": {
    "TaskTimeoutSeconds": 60,
    "MaxRetryCount": 3
  },
  "CvPlc": {
    "TaskReportCount": 5,
    "LocationCount": 10
  },
  "PathConfig": {
    "JsonPath": "Config/paths.json"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/wcs-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
